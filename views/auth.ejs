<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle ? `${pageTitle} | FinPulse` : "FinPulse" %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="auth-page-body">
  <main class="auth-page-shell">
    <section class="auth-hero-panel">
      <p class="eyebrow mb-2">Local Login</p>
      <h1 class="auth-title">FinPulse user setup</h1>
      <p class="auth-copy">
        Create simple local users, switch between business profiles, and keep each user's transactions separate.
      </p>
      <div class="auth-feature-list">
        <span class="auth-feature-pill"><i class="bi bi-person-badge"></i> Name, business, profession, currency</span>
        <span class="auth-feature-pill"><i class="bi bi-image"></i> Optional profile picture</span>
        <span class="auth-feature-pill"><i class="bi bi-shield-lock"></i> Basic password sign-in</span>
      </div>
    </section>

    <section class="auth-card-shell">
      <% if (flash) { %>
        <div class="alert alert-<%= flash.type %> auth-alert" role="alert"><%= flash.message %></div>
      <% } %>

      <div class="auth-grid">
        <article class="auth-card">
          <h2 class="auth-card-title">Sign in</h2>
          <p class="text-muted mb-3">Choose a user and enter the password.</p>

          <% if (users.length === 0) { %>
            <div class="empty-state py-4">
              <p class="mb-0">No users yet. Create the first user to unlock the dashboard.</p>
            </div>
          <% } else { %>
            <form method="POST" action="/auth/login" class="row g-3">
              <input type="hidden" name="redirectTo" value="/dashboard">
              <div class="col-12">
                <label class="form-label fw-semibold">User</label>
                <select class="form-select" name="userId" required>
                  <% users.forEach((user) => { %>
                    <option value="<%= user._id %>"><%= user.name %> · <%= user.businessName %></option>
                  <% }) %>
                </select>
              </div>
              <div class="col-12">
                <label class="form-label fw-semibold">Password</label>
                <input type="password" class="form-control" name="password" minlength="6" required>
              </div>
              <div class="col-12">
                <button class="btn btn-dark w-100" type="submit">
                  <i class="bi bi-box-arrow-in-right me-1"></i>Sign in
                </button>
              </div>
            </form>
          <% } %>
        </article>

        <article class="auth-card">
          <h2 class="auth-card-title">Create user</h2>
          <p class="text-muted mb-3">Add a business profile with a simple local password.</p>

          <form method="POST" action="/auth/users" class="row g-3" data-image-form>
            <input type="hidden" name="redirectTo" value="/dashboard">
            <input type="hidden" name="profileImageData" data-image-hidden>

            <div class="col-12 auth-avatar-builder">
              <div class="auth-avatar-preview" data-image-preview>
                <span>+</span>
              </div>
              <div>
                <label class="form-label fw-semibold">Profile picture</label>
                <input type="file" class="form-control" accept="image/*" data-image-input>
                <div class="form-text">Optional. A small image works best.</div>
              </div>
            </div>

            <div class="col-md-6">
              <label class="form-label fw-semibold">Name</label>
              <input type="text" class="form-control" name="name" maxlength="80" required>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold">Email</label>
              <input type="email" class="form-control" name="email" maxlength="120" required>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold">Password</label>
              <input type="password" class="form-control" name="password" minlength="6" required>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold">Profession</label>
              <input type="text" class="form-control" name="profession" maxlength="80" placeholder="Shop owner, freelancer">
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold">Business name</label>
              <input type="text" class="form-control" name="businessName" maxlength="100" required>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold">Currency</label>
              <select class="form-select" name="currency" required>
                <% validCurrencies.forEach((currency) => { %>
                  <option value="<%= currency %>" <%= currency === "INR" ? "selected" : "" %>><%= currency %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-12">
              <button class="btn btn-success w-100" type="submit">
                <i class="bi bi-person-plus me-1"></i>Create user and continue
              </button>
            </div>
          </form>
        </article>
      </div>
    </section>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/user-management.js"></script>
</body>
</html>

