<%
  const topCategories = Object.entries(categoryBreakdown)
    .sort((first, second) => second[1] - first[1])
    .slice(0, 5);
  const monthlyKeys = Object.keys(monthly).sort().reverse();
  const latestMonthKey = monthlyKeys[0];
  const latestMonth = latestMonthKey ? monthly[latestMonthKey] : null;
  const [latestYear, latestMonthNumber] = latestMonthKey ? latestMonthKey.split("-") : [];
  const monthNames = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
  const latestMonthLabel = latestMonthKey ? `${monthNames[Number(latestMonthNumber) - 1]} ${latestYear}` : "No data yet";
  const strongestMonth = insights.strongestMonth;
  const weakestMonth = insights.weakestMonth;
  const strongestMonthLabel = strongestMonth ? `${monthNames[Number(strongestMonth.key.split('-')[1]) - 1]} ${strongestMonth.key.split('-')[0]}` : "No data yet";
  const weakestMonthLabel = weakestMonth ? `${monthNames[Number(weakestMonth.key.split('-')[1]) - 1]} ${weakestMonth.key.split('-')[0]}` : "No data yet";
%>

<div class="page-header d-flex justify-content-between align-items-start gap-3 mb-4">
  <div>
    <h1 class="page-title">
      <i class="bi bi-list-check me-2 text-success"></i>Summary
    </h1>
    <p class="section-subtitle mb-0">
      A clean snapshot of the business so you can spot profit trends quickly.
    </p>
  </div>
  <a href="/analytics" class="btn btn-outline-dark">
    <i class="bi bi-graph-up me-1"></i>Open Analytics
  </a>
</div>

<%- include("partials/stats", { summary }) %>

<div class="row g-4 mb-4">
  <div class="col-lg-4">
    <div class="chart-card h-100">
      <h5 class="mb-3">
        <i class="bi bi-trophy me-2 text-warning"></i>Best Month
      </h5>
      <% if (!strongestMonth) { %>
        <div class="empty-state py-5">
          <p class="mb-0">Need more monthly data to identify your strongest period.</p>
        </div>
      <% } else { %>
        <ul class="metric-list compact-metrics">
          <li>
            <span class="metric-label">Month</span>
            <span class="metric-value"><%= strongestMonthLabel %></span>
          </li>
          <li>
            <span class="metric-label">Net</span>
            <span class="metric-value text-success">&#8377;<%= strongestMonth.net.toLocaleString("en-IN") %></span>
          </li>
          <li>
            <span class="metric-label">Savings Rate</span>
            <span class="metric-value"><%= insights.savingsRate.toFixed(1) %>%</span>
          </li>
        </ul>
      <% } %>
    </div>
  </div>
  <div class="col-lg-4">
    <div class="chart-card h-100">
      <h5 class="mb-3">
        <i class="bi bi-speedometer me-2 text-primary"></i>Performance Pulse
      </h5>
      <ul class="metric-list compact-metrics">
        <li>
          <span class="metric-label">Tracked Months</span>
          <span class="metric-value"><%= insights.trackedMonths %></span>
        </li>
        <li>
          <span class="metric-label">Average Monthly Net</span>
          <span class="metric-value <%= insights.averageMonthlyNet >= 0 ? "text-success" : "text-danger" %>">
            <%= insights.averageMonthlyNet >= 0 ? "+" : "-" %>&#8377;<%= Math.abs(insights.averageMonthlyNet).toLocaleString("en-IN", { maximumFractionDigits: 0 }) %>
          </span>
        </li>
        <li>
          <span class="metric-label">Weakest Month</span>
          <span class="metric-value"><%= weakestMonthLabel %></span>
        </li>
      </ul>
    </div>
  </div>
  <div class="col-lg-4">
    <div class="chart-card h-100">
      <h5 class="mb-3">
        <i class="bi bi-pie-chart me-2 text-danger"></i>Expense Concentration
      </h5>
      <% if (!insights.topExpenseCategory) { %>
        <div class="empty-state py-5">
          <p class="mb-0">Expense concentration appears once spending is recorded.</p>
        </div>
      <% } else { %>
        <div class="category-spotlight">
          <div class="spotlight-name"><%= insights.topExpenseCategory.name %></div>
          <div class="spotlight-amount text-danger">&#8377;<%= insights.topExpenseCategory.amount.toLocaleString("en-IN") %></div>
          <div class="progress expense-progress mb-2">
            <div class="progress-bar bg-danger" role="progressbar" style="width: <%= Math.min(insights.topExpenseCategory.share, 100) %>%"></div>
          </div>
          <p class="muted-note mb-0"><%= insights.topExpenseCategory.share.toFixed(1) %>% of all recorded expenses come from this category.</p>
        </div>
      <% } %>
    </div>
  </div>
</div>

<div class="row g-4 mb-4">
  <div class="col-lg-6">
    <div class="chart-card h-100">
      <h5 class="mb-3">
        <i class="bi bi-calendar-event me-2 text-primary"></i>Latest Recorded Month
      </h5>

      <% if (!latestMonth) { %>
        <div class="empty-state py-5">
          <p class="mb-0">No monthly rollup available yet.</p>
        </div>
      <% } else { %>
        <ul class="metric-list">
          <li>
            <span class="metric-label">Month</span>
            <span class="metric-value"><%= latestMonthLabel %></span>
          </li>
          <li>
            <span class="metric-label">Income</span>
            <span class="metric-value text-success">&#8377;<%= latestMonth.income.toLocaleString("en-IN") %></span>
          </li>
          <li>
            <span class="metric-label">Expense</span>
            <span class="metric-value text-danger">&#8377;<%= latestMonth.expense.toLocaleString("en-IN") %></span>
          </li>
          <li>
            <span class="metric-label">Net Result</span>
            <span class="metric-value <%= latestMonth.income - latestMonth.expense >= 0 ? "text-success" : "text-danger" %>">
              <%= latestMonth.income - latestMonth.expense >= 0 ? "+" : "-" %>&#8377;<%= Math.abs(latestMonth.income - latestMonth.expense).toLocaleString("en-IN") %>
            </span>
          </li>
        </ul>
      <% } %>
    </div>
  </div>
  <div class="col-lg-6">
    <div class="chart-card h-100">
      <h5 class="mb-3">
        <i class="bi bi-stars me-2 text-warning"></i>Top Expense Categories
      </h5>

      <% if (topCategories.length === 0) { %>
        <div class="empty-state py-5">
          <p class="mb-0">Top categories appear after you record some expenses.</p>
        </div>
      <% } else { %>
        <ul class="insight-list">
          <% topCategories.forEach(([name, amount]) => { %>
            <li>
              <div>
                <div class="fw-semibold"><%= name %></div>
                <div class="muted-note">Expense category</div>
              </div>
              <div class="metric-value text-danger">&#8377;<%= amount.toLocaleString("en-IN") %></div>
            </li>
          <% }) %>
        </ul>
      <% } %>
    </div>
  </div>
</div>

<%- include("partials/monthly-table", { monthly }) %>

<%- include("partials/transaction-modal") %>
