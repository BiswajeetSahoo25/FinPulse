<div class="page-header d-flex justify-content-between align-items-start gap-3 mb-4">
  <div>
    <h1 class="page-title">
      <i class="bi bi-graph-up me-2 text-success"></i>Analytics
    </h1>
    <p class="section-subtitle mb-0">
      Explore spending patterns and revenue trends without leaving the app shell.
    </p>
  </div>
  <a href="/summary" class="btn btn-outline-dark">
    <i class="bi bi-list-check me-1"></i>Open Summary
  </a>
</div>

<div class="row g-4 mb-4">
  <div class="col-lg-7">
    <div class="chart-card h-100">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0">
          <i class="bi bi-bar-chart me-2 text-primary"></i>Monthly Income vs Expense
        </h5>
        <span class="text-muted small">Trend over time</span>
      </div>

      <% if (Object.keys(monthly).length === 0) { %>
        <div class="empty-state py-5">
          <p class="mb-0">No trend data yet. Start logging transactions to unlock analytics.</p>
        </div>
      <% } else { %>
        <canvas id="monthlyChart"></canvas>
      <% } %>
    </div>
  </div>
  <div class="col-lg-5">
    <div class="chart-card h-100">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0">
          <i class="bi bi-pie-chart me-2 text-danger"></i>Expense by Category
        </h5>
        <span class="text-muted small">Spending mix</span>
      </div>

      <% if (Object.keys(categoryBreakdown).length === 0) { %>
        <div class="empty-state py-5">
          <p class="mb-0">Categories will appear after your first expense is saved.</p>
        </div>
      <% } else { %>
        <canvas id="categoryChart"></canvas>
      <% } %>
    </div>
  </div>
</div>

<%- include("partials/monthly-table", { monthly }) %>

<script id="monthly-data" type="application/json"><%- serializedMonthly %></script>
<script id="category-data" type="application/json"><%- serializedCategoryBreakdown %></script>

<%- include("partials/transaction-modal") %>
