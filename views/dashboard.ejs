<div class="page-header d-flex justify-content-between align-items-start gap-3 mb-4">
  <div>
    <h1 class="page-title">
      <i class="bi bi-speedometer2 me-2 text-success"></i>Dashboard
    </h1>
    <p class="section-subtitle mb-0">
      A quick pulse on income, spending, and recent activity.
    </p>
  </div>
  <button
    class="btn btn-success"
    data-bs-toggle="modal"
    data-bs-target="#addTransactionModal"
  >
    <i class="bi bi-plus-circle me-1"></i>Add Transaction
  </button>
</div>

<%- include("partials/stats", { summary }) %>

<div class="row g-4 mb-4">
  <div class="col-lg-7">
    <div class="chart-card h-100">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0">
          <i class="bi bi-bar-chart me-2 text-primary"></i>Monthly Income vs Expense
        </h5>
        <span class="text-muted small">Auto-grouped by month</span>
      </div>
      <% if (Object.keys(monthly).length === 0) { %>
        <div class="empty-state py-5">
          <p class="mb-0">No transaction data yet. Add your first entry to unlock charts.</p>
        </div>
      <% } else { %>
        <canvas id="monthlyChart"></canvas>
      <% } %>
    </div>
  </div>
  <div class="col-lg-5">
    <div class="chart-card h-100">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0">
          <i class="bi bi-pie-chart me-2 text-danger"></i>Expense by Category
        </h5>
        <span class="text-muted small">Spending mix</span>
      </div>
      <% if (Object.keys(categoryBreakdown).length === 0) { %>
        <div class="empty-state py-5">
          <p class="mb-0">Expense categories will appear here once you log spending.</p>
        </div>
      <% } else { %>
        <canvas id="categoryChart"></canvas>
      <% } %>
    </div>
  </div>
</div>

<div class="row g-4">
  <div class="col-xl-8">
    <%- include("partials/monthly-table", { monthly }) %>
  </div>
  <div class="col-xl-4">
    <div class="chart-card h-100">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0">
          <i class="bi bi-clock-history me-2 text-secondary"></i>Recent Transactions
        </h5>
        <a href="/transactions" class="small fw-semibold text-decoration-none">View all</a>
      </div>

      <% if (transactions.length === 0) { %>
        <div class="empty-state py-5">
          <p class="mb-0">No transactions yet.</p>
        </div>
      <% } else { %>
        <div class="recent-list">
          <% transactions.slice(0, 5).forEach((transaction) => { %>
            <div class="recent-item">
              <div>
                <div class="fw-semibold"><%= transaction.category || "General" %></div>
                <div class="text-muted small">
                  <%= transaction.method ? transaction.method.toUpperCase() : "No method" %>
                </div>
              </div>
              <div class="text-end">
                <div class="<%= transaction.type === 'income' ? 'text-success' : 'text-danger' %> fw-semibold">
                  <%= transaction.type === "income" ? "+" : "-" %>&#8377;<%= transaction.amount.toLocaleString("en-IN") %>
                </div>
                <div class="text-muted small">
                  <%= transaction.date && !Number.isNaN(transaction.date.getTime())
                    ? transaction.date.toLocaleDateString("en-IN", { day: "2-digit", month: "short" })
                    : "Unknown" %>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>
</div>

<%- include("partials/transaction-modal") %>

<script id="monthly-data" type="application/json"><%- serializedMonthly %></script>
<script id="category-data" type="application/json"><%- serializedCategoryBreakdown %></script>
