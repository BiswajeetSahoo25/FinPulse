<%
  const MONTHS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  function fmtMonth(key) {
    const [yr, mo] = key.split('-');
    return MONTHS[parseInt(mo, 10) - 1] + ' ' + yr;
  }
%>

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-start mb-4">
  <div>
    <h2 class="fw-bold text-dark mb-0">
      <i class="bi bi-speedometer2 me-2 text-success"></i> Dashboard
    </h2>
    <p class="text-muted small mt-1">Welcome back, Demo User</p>
  </div>
  <button class="btn btn-success" data-bs-toggle="modal" data-bs-target="#addTransactionModal">
    <i class="bi bi-plus-circle me-1"></i> Add Transaction
  </button>
</div>

<!-- Stat Cards -->
<div class="row g-4 mb-4">
  <div class="col-sm-12 col-md-4">
    <div class="stat-card income d-flex justify-content-between align-items-center">
      <div>
        <div class="stat-label"><i class="bi bi-arrow-up-circle me-1"></i> Total Income</div>
        <div class="stat-amount">₹<%= summary.totalIncome.toLocaleString() %></div>
      </div>
      <i class="bi bi-cash-coin stat-icon"></i>
    </div>
  </div>
  <div class="col-sm-12 col-md-4">
    <div class="stat-card expense d-flex justify-content-between align-items-center">
      <div>
        <div class="stat-label"><i class="bi bi-arrow-down-circle me-1"></i> Total Expense</div>
        <div class="stat-amount">₹<%= summary.totalExpense.toLocaleString() %></div>
      </div>
      <i class="bi bi-cart-dash stat-icon"></i>
    </div>
  </div>
  <div class="col-sm-12 col-md-4">
    <div class="stat-card profit d-flex justify-content-between align-items-center">
      <div>
        <div class="stat-label"><i class="bi bi-wallet2 me-1"></i> Net Profit</div>
        <div class="stat-amount">₹<%= summary.profit.toLocaleString() %></div>
      </div>
      <i class="bi bi-graph-up-arrow stat-icon"></i>
    </div>
  </div>
</div>

<!-- Charts -->
<div class="row g-4 mb-4">
  <div class="col-lg-7">
    <div class="chart-card">
      <h5><i class="bi bi-bar-chart me-2 text-primary"></i>Monthly Income vs Expense</h5>
      <canvas id="monthlyChart"></canvas>
    </div>
  </div>
  <div class="col-lg-5">
    <div class="chart-card">
      <h5><i class="bi bi-pie-chart me-2 text-danger"></i>Expense by Category</h5>
      <% if (Object.keys(categoryBreakdown).length === 0) { %>
        <p class="text-muted text-center py-4">No expense data yet.</p>
      <% } else { %>
        <canvas id="categoryChart"></canvas>
      <% } %>
    </div>
  </div>
</div>

<!-- Monthly Breakdown Table -->
<div class="chart-card mb-4">
  <h5><i class="bi bi-calendar3 me-2 text-secondary"></i>Monthly Breakdown</h5>
  <% if (Object.keys(monthly).length === 0) { %>
    <p class="text-muted text-center py-3">No data yet. Add some transactions!</p>
  <% } else { %>
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-dark">
        <tr>
          <th>Month</th>
          <th class="text-success">Income</th>
          <th class="text-danger">Expense</th>
          <th>Net</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% Object.keys(monthly).sort().reverse().forEach(key => {
          const m = monthly[key];
          const net = m.income - m.expense;
        %>
        <tr>
          <td class="fw-semibold"><%= fmtMonth(key) %></td>
          <td class="text-success">₹<%= m.income.toLocaleString() %></td>
          <td class="text-danger">₹<%= m.expense.toLocaleString() %></td>
          <td class="fw-semibold <%= net >= 0 ? 'text-success' : 'text-danger' %>">
            <%= net >= 0 ? '+' : '' %>₹<%= Math.abs(net).toLocaleString() %>
          </td>
          <td>
            <% if (net >= 0) { %>
              <span class="badge bg-success">Profit</span>
            <% } else { %>
              <span class="badge bg-danger">Loss</span>
            <% } %>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>

<!-- Add Transaction Modal -->
<div class="modal fade" id="addTransactionModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header bg-dark text-white">
        <h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i>Add Transaction</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <form id="transactionForm">
          <div class="row g-3">
            <div class="col-6">
              <label class="form-label fw-semibold">Type <span class="text-danger">*</span></label>
              <select class="form-select" name="type" required>
                <option value="">Select...</option>
                <option value="income">Income</option>
                <option value="expense">Expense</option>
              </select>
            </div>
            <div class="col-6">
              <label class="form-label fw-semibold">Amount (₹) <span class="text-danger">*</span></label>
              <input type="number" class="form-control" name="amount" min="1" placeholder="0" required>
            </div>
            <div class="col-6">
              <label class="form-label fw-semibold">Category</label>
              <input type="text" class="form-control" name="category" placeholder="food, rent, salary…">
            </div>
            <div class="col-6">
              <label class="form-label fw-semibold">Method</label>
              <select class="form-select" name="method">
                <option value="">Select...</option>
                <option value="cash">Cash</option>
                <option value="upi">UPI</option>
                <option value="bank">Bank Transfer</option>
                <option value="card">Card</option>
              </select>
            </div>
            <div class="col-12">
              <label class="form-label fw-semibold">Source / Customer</label>
              <input type="text" class="form-control" name="source" placeholder="UPI ID or offline">
            </div>
            <div class="col-12">
              <label class="form-label fw-semibold">Note</label>
              <textarea class="form-control" name="note" rows="2" placeholder="Optional note…"></textarea>
            </div>
          </div>
          <div id="formError" class="alert alert-danger mt-3 d-none"></div>
        </form>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-success" id="submitTransaction">
          <i class="bi bi-check-circle me-1"></i> Save Transaction
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  const MONTHS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  function fmtLabel(key) {
    const [yr, mo] = key.split('-');
    return MONTHS[parseInt(mo, 10) - 1] + ' ' + yr;
  }

  // Monthly Bar Chart
  const monthly = <%- JSON.stringify(monthly) %>;
  const keys = Object.keys(monthly).sort();
  const chartLabels = keys.map(fmtLabel);
  const incomeData  = keys.map(k => monthly[k].income);
  const expenseData = keys.map(k => monthly[k].expense);

  new Chart(document.getElementById('monthlyChart'), {
    type: 'bar',
    data: {
      labels: chartLabels,
      datasets: [
        { label: 'Income',  data: incomeData,  backgroundColor: '#2ecc71', borderRadius: 6 },
        { label: 'Expense', data: expenseData, backgroundColor: '#e74c3c', borderRadius: 6 }
      ]
    },
    options: {
      responsive: true,
      plugins: { legend: { position: 'top' } },
      scales: { y: { beginAtZero: true } }
    }
  });

  <% if (Object.keys(categoryBreakdown).length > 0) { %>
  // Category Doughnut Chart
  const categories = <%- JSON.stringify(categoryBreakdown) %>;
  new Chart(document.getElementById('categoryChart'), {
    type: 'doughnut',
    data: {
      labels: Object.keys(categories),
      datasets: [{
        data: Object.values(categories),
        backgroundColor: ['#3498db','#e74c3c','#2ecc71','#f39c12','#9b59b6','#1abc9c','#e67e22'],
        hoverOffset: 8
      }]
    },
    options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
  });
  <% } %>

  // Add Transaction Submit
  document.getElementById('submitTransaction').addEventListener('click', async () => {
    const form = document.getElementById('transactionForm');
    const data = Object.fromEntries(new FormData(form));
    const errorEl = document.getElementById('formError');
    errorEl.classList.add('d-none');

    if (!data.type || !data.amount) {
      errorEl.textContent = 'Type and amount are required.';
      errorEl.classList.remove('d-none');
      return;
    }
    try {
      const res = await fetch('/transactions', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ...data, amount: parseFloat(data.amount) })
      });
      const result = await res.json();
      if (!res.ok) {
        errorEl.textContent = result.error || 'Something went wrong.';
        errorEl.classList.remove('d-none');
        return;
      }
      window.location.reload();
    } catch (err) {
      errorEl.textContent = 'Network error. Please try again.';
      errorEl.classList.remove('d-none');
    }
  });
</script>
