<%
  const categoryPalette = ["#1d7a58", "#0f766e", "#f97316", "#f59e0b", "#ef4444", "#6366f1"];
  const expenseBreakdown = Object.entries(analytics.categoryBreakdown).sort((entryA, entryB) => entryB[1] - entryA[1]);
  const topExpense = expenseBreakdown[0];
  const latestTransaction = transactions[0];
%>

<section id="dashboard-overview" class="hero-panel">
  <div>
    <p class="eyebrow">Financial health at a glance</p>
    <h2>Clean signals for income, expense, and profit.</h2>
    <p class="hero-text">
      FinPulse keeps <%= user.businessName %> ready for demos and day-to-day decisions
      with a fast, explainable dashboard.
    </p>
  </div>

  <div class="hero-badge">
    <div>
      <span>Top expense</span>
      <strong><%= topExpense ? topExpense[0] : "No expense data yet" %></strong>
    </div>
    <p class="hero-badge-copy">
      <%= topExpense ? `${formatCurrency(topExpense[1])} spent in your biggest category.` : "Add an expense to unlock category insights." %>
    </p>
    <% if (latestTransaction) { %>
      <div class="hero-mini-stat">
        <span>Latest activity</span>
        <strong><%= latestTransaction.category %></strong>
        <small>
          <%= latestTransaction.type %> on
          <%= new Date(latestTransaction.date).toLocaleDateString("en-IN") %>
        </small>
      </div>
    <% } %>
  </div>
</section>

<% if (message) { %>
  <div class="banner success-banner"><%= message %></div>
<% } %>

<section class="summary-grid">
  <article class="summary-card income-card">
    <p>Total Income</p>
    <h3><%= formatCurrency(summary.totalIncome) %></h3>
    <span class="summary-note">Money flowing into the business</span>
  </article>

  <article class="summary-card expense-card">
    <p>Total Expense</p>
    <h3><%= formatCurrency(summary.totalExpense) %></h3>
    <span class="summary-note">Outflows across all spending</span>
  </article>

  <article class="summary-card profit-card">
    <p>Profit</p>
    <h3><%= formatCurrency(summary.profit) %></h3>
    <span class="summary-note">Net result after expenses</span>
  </article>
</section>

<section id="transactions-section" class="content-grid transactions-grid">
  <article class="panel">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Quick entry</p>
        <h3>Add a new transaction</h3>
      </div>
      <span class="pill neutral-pill">Simple form</span>
    </div>

    <form action="/transactions" method="POST" class="transaction-form">
      <div class="field-grid">
        <label>
          <span>Type</span>
          <select name="type" required>
            <option value="income">Income</option>
            <option value="expense">Expense</option>
          </select>
        </label>

        <label>
          <span>Amount</span>
          <input
            type="number"
            step="0.01"
            min="1"
            name="amount"
            placeholder="2500"
            required
          />
        </label>
      </div>

      <div class="field-grid">
        <label>
          <span>Category</span>
          <input type="text" name="category" placeholder="Sales, Rent, Salary" required />
        </label>

        <label>
          <span>Method</span>
          <select name="method" required>
            <option value="upi">UPI</option>
            <option value="cash">Cash</option>
            <option value="bank">Bank</option>
          </select>
        </label>
      </div>

      <div class="field-grid">
        <label>
          <span>Source</span>
          <input type="text" name="source" placeholder="Client payment or vendor" />
        </label>

        <label>
          <span>Date</span>
          <input type="date" name="date" value="<%= formatDateInput() %>" />
        </label>
      </div>

      <label>
        <span>Note</span>
        <textarea
          name="note"
          rows="4"
          placeholder="Add a short context for the transaction"
        ></textarea>
      </label>

      <button type="submit" class="primary-button">Save transaction</button>
    </form>
  </article>

  <article class="panel">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Recent activity</p>
        <h3>Latest transactions</h3>
      </div>
      <a class="text-link" href="/transactions">View JSON</a>
    </div>

    <% if (!transactions.length) { %>
      <div class="empty-state">
        <h4>No transactions yet</h4>
        <p>Add your first income or expense to start building the dashboard.</p>
      </div>
    <% } else { %>
      <div class="table-wrapper">
        <table class="transaction-table">
          <thead>
            <tr>
              <th>Type</th>
              <th>Category</th>
              <th>Method</th>
              <th>Source</th>
              <th>Date</th>
              <th>Amount</th>
            </tr>
          </thead>
          <tbody>
            <% transactions.forEach((transaction) => { %>
              <tr>
                <td>
                  <span class="pill <%= transaction.type === 'income' ? 'income-pill' : 'expense-pill' %>">
                    <%= transaction.type %>
                  </span>
                </td>
                <td><%= transaction.category %></td>
                <td><%= transaction.method %></td>
                <td><%= transaction.source || "-" %></td>
                <td><%= new Date(transaction.date).toLocaleDateString("en-IN") %></td>
                <td class="<%= transaction.type === 'income' ? 'amount-positive' : 'amount-negative' %>">
                  <%= transaction.type === "income" ? "+" : "-" %><%= formatCurrency(transaction.amount) %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </article>
</section>

<section id="analytics-section" class="content-grid analytics-grid">
  <article class="panel chart-panel">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Monthly movement</p>
        <h3>Income vs expense</h3>
      </div>
      <span class="pill neutral-pill">Bar chart</span>
    </div>

    <div class="chart-shell">
      <canvas id="monthlyChart" height="140"></canvas>
    </div>
  </article>

  <article class="panel chart-panel">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Expense split</p>
        <h3>Category breakdown</h3>
      </div>
      <span class="pill neutral-pill">Doughnut</span>
    </div>

    <div class="chart-shell chart-shell-compact">
      <canvas id="categoryChart" height="140"></canvas>
      <div class="chart-empty" id="categoryChartEmpty" hidden>
        Add an expense transaction to see category distribution.
      </div>
    </div>

    <% if (expenseBreakdown.length) { %>
      <div class="category-list">
        <% expenseBreakdown.forEach((entry, index) => { %>
          <div class="category-row">
            <span class="category-label">
              <span
                class="category-dot"
                style="background-color: <%= categoryPalette[index % categoryPalette.length] %>"
              ></span>
              <%= entry[0] %>
            </span>
            <strong><%= formatCurrency(entry[1]) %></strong>
          </div>
        <% }) %>
      </div>
    <% } %>
  </article>
</section>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  const monthlyData = <%- JSON.stringify(analytics.monthly) %>;
  const categoryBreakdown = <%- JSON.stringify(analytics.categoryBreakdown) %>;
  const categoryPalette = <%- JSON.stringify(categoryPalette) %>;

  const monthlyLabels = Object.keys(monthlyData);
  const monthlyIncome = monthlyLabels.map((label) => monthlyData[label].income);
  const monthlyExpense = monthlyLabels.map((label) => monthlyData[label].expense);

  const categoryEntries = Object.entries(categoryBreakdown).sort(
    (entryA, entryB) => entryB[1] - entryA[1]
  );
  const categoryLabels = categoryEntries.map((entry) => entry[0]);
  const categoryValues = categoryEntries.map((entry) => entry[1]);

  const monthlyChartContext = document.getElementById("monthlyChart");
  const categoryChartContext = document.getElementById("categoryChart");
  const categoryChartEmpty = document.getElementById("categoryChartEmpty");
  const currencyFormatter = new Intl.NumberFormat("en-IN", {
    style: "currency",
    currency: "INR",
    maximumFractionDigits: 0,
  });

  new Chart(monthlyChartContext, {
    type: "bar",
    data: {
      labels: monthlyLabels,
      datasets: [
        {
          label: "Income",
          data: monthlyIncome,
          backgroundColor: "#1d7a58",
          borderRadius: 12,
          maxBarThickness: 34,
        },
        {
          label: "Expense",
          data: monthlyExpense,
          backgroundColor: "#ef4444",
          borderRadius: 12,
          maxBarThickness: 34,
        },
      ],
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      interaction: {
        mode: "index",
        intersect: false,
      },
      plugins: {
        legend: {
          position: "top",
          labels: {
            boxWidth: 12,
            usePointStyle: true,
            pointStyle: "circle",
          },
        },
        tooltip: {
          callbacks: {
            label(context) {
              return `${context.dataset.label}: ${currencyFormatter.format(context.parsed.y || 0)}`;
            },
          },
        },
      },
      scales: {
        x: {
          grid: {
            display: false,
          },
          ticks: {
            color: "#6b6b73",
          },
        },
        y: {
          beginAtZero: true,
          ticks: {
            color: "#6b6b73",
            callback(value) {
              return currencyFormatter.format(value);
            },
          },
          grid: {
            color: "rgba(24, 24, 27, 0.08)",
          },
        },
      },
    },
  });

  if (categoryLabels.length) {
    new Chart(categoryChartContext, {
      type: "doughnut",
      data: {
        labels: categoryLabels,
        datasets: [
          {
            data: categoryValues,
            backgroundColor: categoryLabels.map((_, index) => categoryPalette[index % categoryPalette.length]),
            borderColor: "#f7f5ef",
            borderWidth: 4,
            hoverOffset: 12,
          },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        cutout: "62%",
        plugins: {
          legend: {
            display: false,
          },
          tooltip: {
            callbacks: {
              label(context) {
                return `${context.label}: ${currencyFormatter.format(context.parsed || 0)}`;
              },
            },
          },
        },
      },
    });
  } else {
    categoryChartContext.hidden = true;
    categoryChartEmpty.hidden = false;
  }
</script>
