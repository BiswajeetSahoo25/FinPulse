<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle ? `${pageTitle} | FinPulse` : "FinPulse" %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <% const isActive = (path) => currentPath === path ? "active" : ""; %>

  <nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top px-4">
    <a class="navbar-brand fw-bold fs-4" href="/dashboard">
      <i class="bi bi-bar-chart-fill me-2 text-success"></i>FinPulse
    </a>
    <div class="ms-auto text-white-50 small">
      <i class="bi bi-person-circle me-1"></i> <%= currentUser ? currentUser.name : "Guest" %>
    </div>
  </nav>

  <div class="d-flex" id="wrapper">
    <nav id="sidebar" class="bg-dark">
      <div class="sidebar-sticky">
        <% if (currentUser) { %>
          <div class="sidebar-profile">
            <div class="sidebar-avatar <%= currentUser.profileImage ? "has-image" : "" %>">
              <% if (currentUser.profileImage) { %>
                <img src="<%= currentUser.profileImage %>" alt="<%= currentUser.name %> profile picture">
              <% } else { %>
                <span><%= currentUserInitials %></span>
              <% } %>
            </div>
            <div class="sidebar-profile-copy">
              <strong><%= currentUser.name %></strong>
              <span><%= currentUser.businessName %></span>
              <small><%= currentUser.profession || currentUser.email %></small>
            </div>
            <div class="sidebar-profile-actions">
              <button
                class="btn btn-outline-light btn-sm w-100"
                type="button"
                data-bs-toggle="modal"
                data-bs-target="#userManagerModal"
              >
                <i class="bi bi-gear me-1"></i>Manage users
              </button>
              <form method="POST" action="/auth/logout" class="w-100">
                <button class="btn btn-light btn-sm w-100" type="submit">
                  <i class="bi bi-box-arrow-right me-1"></i>Logout
                </button>
              </form>
            </div>
          </div>
        <% } %>

        <ul class="nav flex-column pt-2">
          <li class="nav-item">
            <a class="nav-link text-white <%= isActive('/dashboard') %>" href="/dashboard">
              <i class="bi bi-speedometer2 me-2"></i> Dashboard
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link text-white <%= isActive('/transactions') %>" href="/transactions">
              <i class="bi bi-arrow-left-right me-2"></i> Transactions
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link text-white <%= isActive('/analytics') %>" href="/analytics">
              <i class="bi bi-graph-up me-2"></i> Analytics
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link text-white <%= isActive('/summary') %>" href="/summary">
              <i class="bi bi-list-check me-2"></i> Summary
            </a>
          </li>
        </ul>
      </div>
    </nav>

    <div id="page-content-wrapper">
      <% if (flash) { %>
        <div class="alert alert-<%= flash.type %> shell-alert" role="alert"><%= flash.message %></div>
      <% } %>
      <%- body %>
    </div>
  </div>

  <% if (currentUser) { %>
    <%- include("../partials/user-modal") %>
  <% } %>

  <footer id="footer">
    <div class="footer-shell">
      <div class="footer-brand">
        <div class="footer-logo">
          <i class="bi bi-bar-chart-fill"></i>
        </div>
        <div>
          <h6 class="mb-1">FinPulse</h6>
          <p class="mb-0">Track cash flow, review business health, and turn transaction history into clearer decisions.</p>
        </div>
      </div>

      <div class="footer-actions">
        <span class="footer-note">Income, expense, summary, and analytics in one focused workspace.</span>
        <a
          class="footer-link"
          href="https://github.com/BiswajeetSahoo25/FinPulse"
          target="_blank"
          rel="noreferrer"
        >
          <i class="bi bi-github me-1"></i>GitHub Repository
        </a>
        <span class="footer-copy">&copy; <%= new Date().getFullYear() %> FinPulse</span>
      </div>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
  <script src="/js/charts.js"></script>
  <script src="/js/transactions.js"></script>
  <script src="/js/dashboard.js"></script>
  <script src="/js/transactions-page.js"></script>
  <script src="/js/user-management.js"></script>
</body>
</html>
