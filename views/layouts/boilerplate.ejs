<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle ? `${pageTitle} | FinPulse` : "FinPulse" %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Manrope:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body class="<%= locals.hideShell ? 'auth-screen' : 'app-screen' %>">
    <% if (locals.hideShell) { %>
      <main class="auth-wrapper">
        <%- body %>
      </main>
    <% } else { %>
      <div class="app-shell">
        <%- include("../includes/sidebar") %>

        <div class="main-shell">
          <%- include("../includes/header") %>

          <main class="page-shell">
            <%- body %>
          </main>
        </div>
      </div>
    <% } %>
  </body>
</html>
