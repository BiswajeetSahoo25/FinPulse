<section class="auth-card">
  <div class="auth-copy">
    <p class="eyebrow">FinPulse</p>
    <h1>Welcome back</h1>
    <p>
      Login to view your business dashboard, recent transactions, and analytics.
    </p>
  </div>

  <% if (error) { %>
    <div class="banner error-banner"><%= error %></div>
  <% } %>

  <form action="/login" method="POST" class="auth-form">
    <label>
      <span>Email</span>
      <input
        type="email"
        name="email"
        placeholder="owner@finpulse.com"
        value="<%= formData.email || '' %>"
        required
      />
    </label>

    <label>
      <span>Password</span>
      <input type="password" name="password" placeholder="Enter password" required />
    </label>

    <button type="submit" class="primary-button">Login</button>
  </form>

  <p class="auth-switch">
    New to FinPulse? <a href="/register">Create an account</a>
  </p>
</section>
