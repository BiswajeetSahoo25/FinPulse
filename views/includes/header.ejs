<header class="topbar">
  <div class="topbar-copy">
    <p class="eyebrow">Live business workspace</p>
    <div class="identity-stack">
      <h1><%= currentUser.businessName %></h1>
      <p class="identity-meta"><%= currentUser.name %> managing the FinPulse dashboard</p>
    </div>
  </div>

  <div class="profile-card">
    <img
      src="<%= currentUser.avatar %>"
      alt="<%= currentUser.name %>"
      class="avatar-lg"
    />
  </div>
</header>
