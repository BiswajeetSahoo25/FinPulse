<aside class="sidebar">
  <div class="sidebar-top">
    <div class="brand-block">
      <div class="brand-mark">FP</div>
      <div>
        <p class="eyebrow sidebar-eyebrow">Fintech MVP</p>
        <h2>FinPulse</h2>
      </div>
    </div>

    <p class="sidebar-copy">
      Simple, explainable business finance tracking for fast-moving demo days.
    </p>

    <nav class="sidebar-nav">
      <a
        class="nav-link"
        href="/dashboard#dashboard-overview"
        data-nav-target="dashboard-overview"
      >
        <span>Dashboard</span>
        <small>Overview</small>
      </a>
      <a
        class="nav-link"
        href="/dashboard#transactions-section"
        data-nav-target="transactions-section"
      >
        <span>Transactions</span>
        <small>Cash flow</small>
      </a>
      <a
        class="nav-link"
        href="/dashboard#analytics-section"
        data-nav-target="analytics-section"
      >
        <span>Analytics</span>
        <small>Insights</small>
      </a>
    </nav>
  </div>

  <div class="sidebar-footer">
    <div class="user-chip">
      <img
        src="<%= currentUser.avatar %>"
        alt="<%= currentUser.name %>"
        class="avatar-sm"
      />
      <div>
        <strong><%= currentUser.name %></strong>
        <span><%= currentUser.businessName %></span>
      </div>
    </div>

    <a class="logout-link" href="/logout">Sign out</a>
  </div>
</aside>
