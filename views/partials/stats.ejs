<div class="row g-4 mb-4">
  <div class="col-sm-12 col-md-4">
    <div class="stat-card income d-flex justify-content-between align-items-center">
      <div>
        <div class="stat-label">
          <i class="bi bi-arrow-up-circle me-1"></i>Total Income
        </div>
        <div class="stat-amount">&#8377;<%= Number(summary.totalIncome).toLocaleString("en-IN") %></div>
      </div>
      <i class="bi bi-cash-coin stat-icon"></i>
    </div>
  </div>
  <div class="col-sm-12 col-md-4">
    <div class="stat-card expense d-flex justify-content-between align-items-center">
      <div>
        <div class="stat-label">
          <i class="bi bi-arrow-down-circle me-1"></i>Total Expense
        </div>
        <div class="stat-amount">&#8377;<%= Number(summary.totalExpense).toLocaleString("en-IN") %></div>
      </div>
      <i class="bi bi-cart-dash stat-icon"></i>
    </div>
  </div>
  <div class="col-sm-12 col-md-4">
    <div class="stat-card profit d-flex justify-content-between align-items-center">
      <div>
        <div class="stat-label">
          <i class="bi bi-wallet2 me-1"></i>Net Profit
        </div>
        <div class="stat-amount">&#8377;<%= Number(summary.profit).toLocaleString("en-IN") %></div>
      </div>
      <i class="bi bi-graph-up-arrow stat-icon"></i>
    </div>
  </div>
</div>
